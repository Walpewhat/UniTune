# ==============================================
# UniTune — .env for the packaged Electron build.
# Copy this file to .env.production BEFORE running `npm run package:win`.
# It will be bundled into the installer as a plain-text file
# and read at app startup on the user's machine.
# ==============================================

# Must stay http://127.0.0.1:3000 — the bundled Next.js server listens there.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Supabase — public by design, safe to ship.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Token encryption. Low-medium risk if extracted — decrypting stored
# tokens still requires access to the user's provider_connections row,
# which is protected by Supabase RLS. Do NOT rotate after shipping:
# existing users will lose their provider connections.
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES

# Spotify — PKCE flow, no client_secret needed.
# In the Spotify Dashboard make sure the redirect URI
# http://127.0.0.1:3000/api/auth/spotify/callback is registered.
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback

# SoundCloud (optional — unlocks search if you still have a legacy key).
SOUNDCLOUD_CLIENT_ID=
